# Copie para .env se quiser ativar solicitação de acesso via Telegram.
# Atenção: em PWA estático, variáveis VITE_* vão para o bundle do navegador.
# Para produção real, o correto é proxy/backend serverless para proteger o token.
VITE_TELEGRAM_BOT_TOKEN=coloque_o_token_aqui
VITE_TELEGRAM_CHAT_ID=coloque_o_chat_id_aqui
